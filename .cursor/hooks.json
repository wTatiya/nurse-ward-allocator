{
  "permissions": {
    "allow": [
      "mcp__agent-skills-standard__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \".cursor/hooks/preedit-skill-loader.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
