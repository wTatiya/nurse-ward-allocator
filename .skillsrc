registry: https://github.com/HoangNguyen0403/agent-skills-standard
agents:
  - cursor
skills:
  react:
    ref: react-v1.3.6
    exclude:
      - react-state-management
  typescript:
    ref: typescript-v1.3.3
  common:
    ref: common-v2.2.2
    exclude:
      - common-observability
      - common-mobile-animation
      - common-mobile-ux-core
      - common-mobile-visual-testing
      - common-ui-design
      - common-dast-tooling
      - common-pentest-methodology
      - common-exploit-verification
      - common-store-changelog
      - common-llm-security
# Project-only skills (NOT synced — keep in repo; restore from git if missing after sync):
# contextual-skill-router, vite-manual-chunks, web-performance-optimization,
# webapp-testing, common/cursor-inventory, common/common-skills-audit, common/vibe-code-auditor
#
# Post-sync checklist (2026-07-10):
# 1. git checkout HEAD -- .cursor/skills/common/{common-skills-audit,cursor-inventory,vibe-code-auditor}
# 2. Delete .cursor/rules/agent-skill-standard-rule.mdc if duplicate of general/ reappeared
# 3. node .cursor/skills/common/cursor-inventory/scripts/inventory.mjs --out .cursor/skills/common/cursor-inventory/INVENTORY.md
# 4. Verify AGENTS.md router + project-only table intact; confirm 18 subagents on disk (delete enterprise specialists if reappeared)
custom_overrides: []
workflows: false
mcp:
  enabled: true
  scope: user
  prompted: true
